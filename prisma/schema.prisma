// This is your Prisma schema file,
// Updated for soft-delete support
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserType {
  ADMIN
  HPAC_MEMBER
  EMPLOYEE
}

enum AwardStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         String   @id @default(cuid())
  employeeId String   @unique @map("employee_id")
  password   String
  userType   UserType @map("user_type")
  employee   Employee @relation(fields: [employeeId], references: [employeeId])
  awards     Award[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  requiresPasswordChange Boolean @default(false) @map("requires_password_change")

  @@map("USER")
}

model Employee {
  employeeId       String  @id @map("employee_id")
  firstname        String
  middleName       String? @map("middle_name")
  lastname         String
  suffix           String?
  position         String
  section          String
  employmentStatus String    @map("employment_status")
  deletedAt        DateTime? @map("deleted_at")
  user             User?
  nominationsMade  Nomination[] @relation("Nominator")
  nominationsReceived Nomination[] @relation("Nominee")

  @@map("bgh_employees")
}

model Award {
  id          String      @id @default(cuid())
  name        String
  description String
  status      AwardStatus @default(PENDING)
  createdById String      @map("created_by_id")
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  nominations Nomination[]

  @@map("awards")
}

model Nomination {
  id          String   @id @default(cuid())
  awardId     String   @map("award_id")
  nomineeId   String   @map("nominee_id")
  nominatorId String   @map("nominator_id")
  reason      String?
  createdAt   DateTime @default(now())

  award       Award    @relation(fields: [awardId], references: [id])
  nominee     Employee @relation("Nominee", fields: [nomineeId], references: [employeeId])
  nominator   Employee @relation("Nominator", fields: [nominatorId], references: [employeeId])

  @@unique([awardId, nominatorId]) // One nomination per award per user
  @@map("nominations")
}
